# ============================================
# DA-PFC Project .gitignore
# ============================================

# --- 仿真输出 (数据文件太大, 不应入库) ---
# 忽略 outputs 下的所有内容, 但保留 sweep 结果
outputs/*
!outputs/sweep_*/
outputs/sweep_*/*
!outputs/sweep_*/*.json
!outputs/sweep_*/*.png

# --- Checkpoints (包含 final_state tensor, 不应入库) ---
checkpoints/

# --- Python 缓存 ---
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/

# --- Jupyter Notebook ---
.ipynb_checkpoints/

# --- IDE / 编辑器 ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- 操作系统 ---
.DS_Store
Thumbs.db

# --- 临时文件 ---
tmp/
*.log
*.tmp
project_report.txt

# --- 临时分析脚本 (根目录散落的临时 py 文件) ---
/analyze_*.py
/check_*.py
/test_*.py

# --- 其他临时文件 ---
_log.txt
_out.txt
_push.txt
push_result.txt
test_out.txt

# --- Sweep 临时文件 ---
sweep_check.txt
sweep_final.txt
sweep_pid.txt
sweep_progress.txt
sweep_status.txt
